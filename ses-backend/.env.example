# Copy this file to `.env` and fill in real values.
# The real `.env` is git-ignored and auto-loaded by Spring Boot via
# `spring.config.import` in src/main/resources/application.yaml.
#
# File format: Java .properties (KEY=VALUE, one per line, no quotes).

# Base64-encoded HMAC-SHA256 secret; must decode to at least 32 bytes.
# Generate one with:  openssl rand -base64 48
app.jwt.secret=REPLACE_WITH_BASE64_ENCODED_SECRET_AT_LEAST_32_BYTES

# PostgreSQL connection (loaded by Spring via spring.config.import).
# Leave the password blank if your local Postgres uses trust auth on
# localhost; set it for any non-dev environment.
spring.datasource.url=jdbc:postgresql://localhost:5432/eventsphere
spring.datasource.username=postgres
spring.datasource.password=
