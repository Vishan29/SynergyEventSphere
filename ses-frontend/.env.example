# SynergyEventSphere frontend environment template.
# Copy to `.env.local` (git-ignored) and adjust as needed.

# Base URL for the Spring Boot API.
# - Dev: leave empty so Vite's proxy at /api -> http://localhost:8080 handles it.
# - Prod: set to the deployed origin (e.g. https://api.example.com).
VITE_API_BASE_URL=

# Toggle the social-login flow once the backend exposes /api/auth/oauth/...
VITE_OAUTH_ENABLED=false
