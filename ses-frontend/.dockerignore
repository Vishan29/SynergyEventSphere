# Node + build artefacts — rebuilt inside the image.
node_modules/
dist/
.vite/
*.tsbuildinfo
.eslintcache
.stylelintcache
coverage/

# IDE / editor scaffolding.
.idea/
.vscode/
*.code-workspace

# OS junk + logs.
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local secrets — never bake into an image.
.env
.env.*
!.env.example

# Don't recursively COPY a Dockerfile into itself.
Dockerfile
.dockerignore
